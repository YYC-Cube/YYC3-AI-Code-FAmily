# YYC³ AI Code Environment Variables

# ============================================
# Application Configuration
# ============================================
VITE_APP_NAME=YYC³ AI Code
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# ============================================
# API Configuration
# ============================================
# Backend API URL
VITE_API_URL=http://localhost:3000/api

# WebSocket URL for real-time collaboration
VITE_WS_URL=ws://localhost:3000/ws

# ============================================
# AI Service Configuration
# ============================================
# Default AI Provider (openai, anthropic, zhipu, baidu, alibaba, ollama)
VITE_AI_DEFAULT_PROVIDER=openai

# OpenAI Configuration
VITE_OPENAI_API_KEY=your-openai-api-key-here
VITE_OPENAI_BASE_URL=https://api.openai.com/v1
VITE_OPENAI_MODEL=gpt-4o-mini

# Anthropic Configuration
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key-here
VITE_ANTHROPIC_BASE_URL=https://api.anthropic.com
VITE_ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Zhipu AI Configuration
VITE_ZHIPU_API_KEY=your-zhipu-api-key-here
VITE_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
VITE_ZHIPU_MODEL=glm-4

# Baidu Wenxin Configuration
VITE_BAIDU_API_KEY=your-baidu-api-key-here
VITE_BAIDU_SECRET_KEY=your-baidu-secret-key-here
VITE_BAIDU_MODEL=ernie-4.0-8k

# Alibaba Tongyi Configuration
VITE_ALIBABA_API_KEY=your-alibaba-api-key-here
VITE_ALIBABA_BASE_URL=https://dashscope.aliyuncs.com/api/v1
VITE_ALIBABA_MODEL=qwen-plus

# Ollama Configuration (Local)
VITE_OLLAMA_BASE_URL=http://localhost:11434
VITE_OLLAMA_MODEL=llama2

# ============================================
# Database Configuration
# ============================================
# Database Type (sqlite, mysql, postgresql)
VITE_DB_TYPE=sqlite

# SQLite Configuration
VITE_SQLITE_PATH=./data/db.sqlite

# MySQL Configuration
VITE_MYSQL_HOST=localhost
VITE_MYSQL_PORT=3306
VITE_MYSQL_DATABASE=yyc3_db
VITE_MYSQL_USER=root
VITE_MYSQL_PASSWORD=your-mysql-password

# PostgreSQL Configuration
VITE_POSTGRES_HOST=localhost
VITE_POSTGRES_PORT=5432
VITE_POSTGRES_DATABASE=yyc3_db
VITE_POSTGRES_USER=postgres
VITE_POSTGRES_PASSWORD=your-postgres-password

# ============================================
# Authentication Configuration
# ============================================
# JWT Secret (for development only, use environment variable in production)
VITE_JWT_SECRET=your-jwt-secret-key-here

# Session Timeout (in minutes)
VITE_SESSION_TIMEOUT=30

# Enable OpenID Connect
VITE_ENABLE_OIDC=true

# OpenID Connect Provider URL
VITE_OIDC_ISSUER=https://accounts.google.com
VITE_OIDC_CLIENT_ID=your-oidc-client-id
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback

# ============================================
# Feature Flags
# ============================================
# Enable AI Features
VITE_ENABLE_AI=true

# Enable Real-time Collaboration
VITE_ENABLE_COLLAB=true

# Enable Code Generation
VITE_ENABLE_CODE_GEN=true

# Enable Database Management
VITE_ENABLE_DB=true

# Enable File System
VITE_ENABLE_FS=true

# Enable Multi-instance
VITE_ENABLE_MULTI_INSTANCE=true

# ============================================
# Performance Configuration
# ============================================
# Enable Performance Monitoring
VITE_ENABLE_PERFORMANCE_MONITOR=true

# Cache TTL (in seconds)
VITE_CACHE_TTL=300

# Rate Limit (requests per minute)
VITE_RATE_LIMIT=60

# ============================================
# Logging Configuration
# ============================================
# Log Level (debug, info, warn, error)
VITE_LOG_LEVEL=debug

# Enable Console Logging
VITE_ENABLE_CONSOLE_LOG=true

# Enable Remote Logging
VITE_ENABLE_REMOTE_LOG=false

# Remote Log URL
VITE_REMOTE_LOG_URL=https://logs.yyc3.com/api/logs

# ============================================
# UI/UX Configuration
# ============================================
# Default Theme (light, dark, auto)
VITE_DEFAULT_THEME=dark

# Default Language (zh-CN, en-US)
VITE_DEFAULT_LANGUAGE=zh-CN

# Enable Animations
VITE_ENABLE_ANIMATIONS=true

# Animation Duration (in milliseconds)
VITE_ANIMATION_DURATION=300

# ============================================
# Development Configuration
# ============================================
# Enable Hot Module Replacement
VITE_ENABLE_HMR=true

# Enable Source Maps
VITE_ENABLE_SOURCE_MAPS=true

# Port for Development Server
VITE_DEV_PORT=5173

# Host for Development Server
VITE_DEV_HOST=localhost

# ============================================
# Testing Configuration
# ============================================
# Enable Test Mode
VITE_TEST_MODE=false

# Test API URL
VITE_TEST_API_URL=http://localhost:3001/api

# Mock API Responses
VITE_MOCK_API=false

# ============================================
# Analytics Configuration
# ============================================
# Enable Analytics
VITE_ENABLE_ANALYTICS=false

# Analytics Provider (google, mixpanel, custom)
VITE_ANALYTICS_PROVIDER=google

# Google Analytics ID
VITE_GA_ID=your-ga-id-here

# ============================================
# Error Reporting Configuration
# ============================================
# Enable Error Reporting
VITE_ENABLE_ERROR_REPORTING=false

# Sentry DSN
VITE_SENTRY_DSN=your-sentry-dsn-here

# ============================================
# CDN Configuration
# ============================================
# Enable CDN
VITE_ENABLE_CDN=false

# CDN Base URL
VITE_CDN_BASE_URL=https://cdn.yyc3.com

# ============================================
# Storage Configuration
# ============================================
# Storage Type (local, indexeddb, cloud)
VITE_STORAGE_TYPE=local

# Cloud Storage Provider (aws, azure, aliyun)
VITE_CLOUD_STORAGE_PROVIDER=aws

# AWS S3 Configuration
VITE_AWS_S3_BUCKET=your-bucket-name
VITE_AWS_REGION=us-east-1
VITE_AWS_ACCESS_KEY_ID=your-access-key-id
VITE_AWS_SECRET_ACCESS_KEY=your-secret-access-key

# ============================================
# Security Configuration
# ============================================
# Enable Content Security Policy
VITE_ENABLE_CSP=true

# CORS Allowed Origins
VITE_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Enable HTTPS
VITE_ENABLE_HTTPS=false

# SSL Certificate Path
VITE_SSL_CERT_PATH=./certs/server.crt
VITE_SSL_KEY_PATH=./certs/server.key

# ============================================
# Plugin Configuration
# ============================================
# Enable Plugin System
VITE_ENABLE_PLUGINS=true

# Plugin Registry URL
VITE_PLUGIN_REGISTRY_URL=https://plugins.yyc3.com

# ============================================
# Deployment Configuration
# ============================================
# Deployment Environment (development, staging, production)
VITE_DEPLOY_ENV=development

# Deployment URL
VITE_DEPLOY_URL=http://localhost:5173

# Enable Auto-deployment
VITE_ENABLE_AUTO_DEPLOY=false

# Deployment Webhook URL
VITE_DEPLOY_WEBHOOK_URL=https://deploy.yyc3.com/webhook

# ============================================
# Internationalization Configuration
# ============================================
# Enable i18n
VITE_ENABLE_I18N=true

# Supported Languages
VITE_SUPPORTED_LANGUAGES=zh-CN,en-US,ja-JP,ko-KR

# Fallback Language
VITE_FALLBACK_LANGUAGE=en-US

# ============================================
# Accessibility Configuration
# ============================================
# Enable Accessibility Features
VITE_ENABLE_A11Y=true

# Enable Screen Reader Support
VITE_ENABLE_SCREEN_READER=true

# Enable Keyboard Navigation
VITE_ENABLE_KEYBOARD_NAV=true

# ============================================
# Advanced Configuration
# ============================================
# Enable Experimental Features
VITE_ENABLE_EXPERIMENTAL=false

# Feature Flags (comma-separated)
VITE_FEATURE_FLAGS=feature1,feature2,feature3

# Custom Configuration
VITE_CUSTOM_CONFIG={}
